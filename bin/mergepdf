#!/bin/bash
# Merge multiple PDFs into one using ghostscript
# Usage: mergepdf output.pdf input1.pdf input2.pdf ...
output="$1"
input="${@:2}"

if [ -z "$output" ] || [ -z "$input" ]; then
    echo "Usage: mergepdf output.pdf input1.pdf input2.pdf ..."
    exit 1
fi

gs -dBATCH -dNOPAUSE -q -sDEVICE=pdfwrite -dPDFSETTINGS=/prepress -sOutputFile="$output" $input
